#!/usr/bin/env bash
set -euo pipefail

# gt-rescue: Recover branches from gt-drain snapshots.
#
# Usage:
#   gt-rescue                          # List all snapshots
#   gt-rescue show <id>                # Show snapshot details (branches, diffs, SHAs)
#   gt-rescue show --last              # Show most recent snapshot
#   gt-rescue diff <id> [branch]       # Compare snapshot vs current state
#   gt-rescue diff --last [branch]     # Compare most recent snapshot vs current
#   gt-rescue restore <id> [branch]    # Restore branch(es) to snapshot state
#   gt-rescue restore --last [branch]  # Restore from most recent snapshot
#   gt-rescue clean [--keep N]         # Delete old snapshots (default: keep 10)
#
# Snapshots are created automatically by gt-drain before every restack.
# Stored at: ~/.gt-drain/snapshots/

SNAPSHOT_DIR="$HOME/.gt-drain/snapshots"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

log()  { echo -e "${BLUE}[gt-rescue]${NC} $1"; }
ok()   { echo -e "${GREEN}[gt-rescue]${NC} $1"; }
warn() { echo -e "${YELLOW}[gt-rescue]${NC} $1"; }
err()  { echo -e "${RED}[gt-rescue]${NC} $1"; }

# ─── Resolve snapshot ID (supports --last) ───────────────────────
resolve_id() {
    local id="${1:---last}"
    if [[ "$id" == "--last" ]]; then
        id=$(ls -1 "$SNAPSHOT_DIR" 2>/dev/null | sort -r | head -1)
        if [[ -z "$id" ]]; then
            err "No snapshots found."
            exit 1
        fi
    fi

    local path="$SNAPSHOT_DIR/$id"
    if [[ ! -d "$path" ]]; then
        err "Snapshot not found: $id"
        err "Run 'gt-rescue' to list available snapshots."
        exit 1
    fi
    echo "$id"
}

# ─── List all snapshots ──────────────────────────────────────────
cmd_list() {
    if [[ ! -d "$SNAPSHOT_DIR" ]] || [[ -z "$(ls -A "$SNAPSHOT_DIR" 2>/dev/null)" ]]; then
        log "No snapshots found."
        log "Snapshots are created automatically by gt-drain."
        return
    fi

    echo ""
    echo -e "${BOLD}  SNAPSHOTS${NC}  (~/.gt-drain/snapshots/)"
    echo "  ────────────────────────────────────────────────"

    for snap_dir in $(ls -1d "$SNAPSHOT_DIR"/*/ 2>/dev/null | sort -r); do
        local id
        id=$(basename "$snap_dir")
        local branch_count
        branch_count=$(wc -l < "$snap_dir/branches.txt" 2>/dev/null | tr -d ' ' || echo "?")
        local timestamp=""
        if [[ -f "$snap_dir/manifest.json" ]]; then
            timestamp=$(grep '"timestamp"' "$snap_dir/manifest.json" 2>/dev/null | sed 's/.*": "//;s/".*//' || echo "")
        fi
        local repo=""
        if [[ -f "$snap_dir/manifest.json" ]]; then
            repo=$(grep '"repo"' "$snap_dir/manifest.json" 2>/dev/null | sed 's/.*": "//;s/".*//' || echo "")
        fi

        local total_size=0
        while IFS= read -r branch; do
            [[ -z "$branch" ]] && continue
            if [[ -f "$snap_dir/$branch/diff.patch" ]]; then
                local s
                s=$(wc -c < "$snap_dir/$branch/diff.patch" | tr -d ' ')
                total_size=$((total_size + s))
            fi
        done < "$snap_dir/branches.txt"

        local size_human
        if [[ "$total_size" -gt 1048576 ]]; then
            size_human="$(( total_size / 1048576 ))MB"
        elif [[ "$total_size" -gt 1024 ]]; then
            size_human="$(( total_size / 1024 ))KB"
        else
            size_human="${total_size}B"
        fi

        echo -e "  ${CYAN}${id}${NC}  ${branch_count} branches  ${size_human}  ${DIM}${repo}${NC}"
    done
    echo ""
    echo -e "  ${DIM}Use 'gt-rescue show <id>' for details${NC}"
    echo -e "  ${DIM}Use 'gt-rescue show --last' for most recent${NC}"
    echo ""
}

# ─── Show snapshot details ────────────────────────────────────────
cmd_show() {
    local id
    id=$(resolve_id "${1:-}")
    local snap_path="$SNAPSHOT_DIR/$id"

    echo ""
    echo -e "${BOLD}  SNAPSHOT: ${id}${NC}"
    echo "  ────────────────────────────────────────────────"

    if [[ -f "$snap_path/manifest.json" ]]; then
        echo -e "  ${DIM}$(cat "$snap_path/manifest.json")${NC}"
        echo ""
    fi

    echo -e "  ${BOLD}Branch${NC}                              ${BOLD}SHA${NC}          ${BOLD}Commits${NC}  ${BOLD}Files${NC}  ${BOLD}Diff${NC}"
    echo "  ──────────────────────────────────  ───────────  ───────  ─────  ────────"

    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue
        local branch_dir="$snap_path/$branch"
        [[ ! -d "$branch_dir" ]] && continue

        local sha commits files diff_size
        sha=$(head -c 11 "$branch_dir/sha.txt" 2>/dev/null || echo "???")
        commits=$(cat "$branch_dir/commit_count.txt" 2>/dev/null || echo "?")
        files=$(wc -l < "$branch_dir/files.txt" 2>/dev/null | tr -d ' ' || echo "?")
        diff_size=$(wc -c < "$branch_dir/diff.patch" 2>/dev/null | tr -d ' ' || echo "0")

        if [[ "$diff_size" -gt 1024 ]]; then
            diff_size="$(( diff_size / 1024 ))KB"
        else
            diff_size="${diff_size}B"
        fi

        printf "  %-36s  %s  %7s  %5s  %s\n" "$branch" "$sha" "$commits" "$files" "$diff_size"
    done < "$snap_path/branches.txt"

    echo ""
    echo -e "  ${DIM}Commands:${NC}"
    echo -e "  ${DIM}  gt-rescue diff ${id}              — compare all branches vs current${NC}"
    echo -e "  ${DIM}  gt-rescue diff ${id} <branch>     — compare one branch${NC}"
    echo -e "  ${DIM}  gt-rescue restore ${id}           — restore all branches${NC}"
    echo -e "  ${DIM}  gt-rescue restore ${id} <branch>  — restore one branch${NC}"
    echo ""
}

# ─── Diff: compare snapshot vs current state ─────────────────────
cmd_diff() {
    local id
    id=$(resolve_id "${1:-}")
    local target_branch="${2:-}"
    local snap_path="$SNAPSHOT_DIR/$id"

    echo ""
    log "Comparing snapshot ${id} against current state..."
    echo ""

    local current_branch
    current_branch=$(git branch --show-current)

    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue

        # If user specified a branch, skip others
        if [[ -n "$target_branch" && "$branch" != "$target_branch" ]]; then
            continue
        fi

        local branch_dir="$snap_path/$branch"
        [[ ! -d "$branch_dir" ]] && continue

        local old_sha new_sha
        old_sha=$(cat "$branch_dir/sha.txt" 2>/dev/null || echo "")

        # Check if branch still exists
        if ! git rev-parse --verify "$branch" >/dev/null 2>&1; then
            err "  ${branch}: GONE — branch no longer exists"
            err "    Snapshot SHA: ${old_sha}"
            continue
        fi

        new_sha=$(git rev-parse "$branch" 2>/dev/null || echo "")

        if [[ "$old_sha" == "$new_sha" ]]; then
            ok "  ${branch}: identical (${old_sha:0:11})"
            continue
        fi

        # SHA changed — investigate what's different
        echo -e "  ${YELLOW}${branch}${NC}: SHA changed"
        echo -e "    ${DIM}snapshot: ${old_sha:0:11}${NC}"
        echo -e "    ${DIM}current:  ${new_sha:0:11}${NC}"

        # Compare file lists
        gt checkout "$branch" 2>/dev/null || continue
        local parent
        parent=$(cat "$branch_dir/parent.txt" 2>/dev/null || echo "main")
        local commit_count
        commit_count=$(git log --oneline "$parent".."$branch" 2>/dev/null | wc -l | tr -d ' ')

        local old_files new_files
        old_files=$(cat "$branch_dir/files.txt" 2>/dev/null | sort)
        if [[ "$commit_count" -gt 0 ]]; then
            new_files=$(git diff --name-only "HEAD~${commit_count}..HEAD" 2>/dev/null | sort || true)
        else
            new_files=""
        fi

        local lost_files gained_files
        lost_files=$(comm -23 <(echo "$old_files") <(echo "$new_files") 2>/dev/null || true)
        gained_files=$(comm -13 <(echo "$old_files") <(echo "$new_files") 2>/dev/null || true)

        if [[ -n "$lost_files" ]]; then
            echo -e "    ${RED}Files LOST:${NC}"
            echo "$lost_files" | while IFS= read -r f; do
                [[ -n "$f" ]] && echo -e "      ${RED}- $f${NC}"
            done
        fi

        if [[ -n "$gained_files" ]]; then
            echo -e "    ${GREEN}Files GAINED:${NC}"
            echo "$gained_files" | while IFS= read -r f; do
                [[ -n "$f" ]] && echo -e "      ${GREEN}+ $f${NC}"
            done
        fi

        if [[ -z "$lost_files" && -z "$gained_files" ]]; then
            echo -e "    ${DIM}Same files, different content (rebased)${NC}"
        fi

        echo ""
    done < "$snap_path/branches.txt"

    gt checkout "$current_branch" 2>/dev/null || true
}

# ─── Restore: reset branches to snapshot state ───────────────────
cmd_restore() {
    local id
    id=$(resolve_id "${1:-}")
    local target_branch="${2:-}"
    local snap_path="$SNAPSHOT_DIR/$id"

    echo ""
    log "Restoring from snapshot ${id}..."

    # Show what will be restored
    echo ""
    echo -e "${BOLD}  Branches to restore:${NC}"

    local restore_list=()
    while IFS= read -r branch; do
        [[ -z "$branch" ]] && continue
        if [[ -n "$target_branch" && "$branch" != "$target_branch" ]]; then
            continue
        fi

        local branch_dir="$snap_path/$branch"
        [[ ! -d "$branch_dir" ]] && continue

        local old_sha new_sha
        old_sha=$(cat "$branch_dir/sha.txt" 2>/dev/null || echo "")

        if ! git rev-parse --verify "$branch" >/dev/null 2>&1; then
            warn "  ${branch}: branch doesn't exist — will recreate"
            restore_list+=("$branch")
            continue
        fi

        new_sha=$(git rev-parse "$branch" 2>/dev/null || echo "")
        if [[ "$old_sha" == "$new_sha" ]]; then
            ok "  ${branch}: already at snapshot state — skipping"
        else
            echo -e "  ${YELLOW}${branch}${NC}: ${new_sha:0:11} → ${old_sha:0:11}"
            restore_list+=("$branch")
        fi
    done < "$snap_path/branches.txt"

    if [[ ${#restore_list[@]} -eq 0 ]]; then
        ok "Nothing to restore — all branches match snapshot."
        return
    fi

    echo ""
    echo -e "${RED}${BOLD}  ⚠  This will hard-reset ${#restore_list[@]} branch(es) to their snapshot SHAs.${NC}"
    echo -e "${DIM}  Current commits on those branches WILL be replaced.${NC}"
    echo ""
    read -rp "  Continue? [y/N] " confirm
    if [[ "${confirm,,}" != "y" ]]; then
        log "Aborted."
        return
    fi
    echo ""

    local current_branch
    current_branch=$(git branch --show-current)

    for branch in "${restore_list[@]}"; do
        local branch_dir="$snap_path/$branch"
        local old_sha
        old_sha=$(cat "$branch_dir/sha.txt" 2>/dev/null || echo "")

        if [[ -z "$old_sha" ]]; then
            err "  ${branch}: no SHA in snapshot — skipping"
            continue
        fi

        # Check if the SHA still exists in the repo
        if ! git cat-file -e "$old_sha" 2>/dev/null; then
            err "  ${branch}: SHA ${old_sha:0:11} no longer exists in repo (may have been GC'd)"
            err "    The diff patch is still at: $branch_dir/diff.patch"
            continue
        fi

        if git rev-parse --verify "$branch" >/dev/null 2>&1; then
            # Branch exists — checkout and reset
            gt checkout "$branch" 2>/dev/null || git checkout "$branch" 2>/dev/null
            git reset --hard "$old_sha"
            ok "  ${branch}: restored → ${old_sha:0:11}"
        else
            # Branch doesn't exist — create it at the old SHA
            git branch "$branch" "$old_sha"
            ok "  ${branch}: recreated at ${old_sha:0:11}"
        fi
    done

    gt checkout "$current_branch" 2>/dev/null || true

    echo ""
    ok "Restore complete."
    warn "Run 'gt submit --stack --no-edit --no-interactive' to push restored state."
    echo ""
}

# ─── Clean: delete old snapshots ─────────────────────────────────
cmd_clean() {
    local keep=10
    if [[ "${1:-}" == "--keep" && -n "${2:-}" ]]; then
        keep="$2"
    fi

    if [[ ! -d "$SNAPSHOT_DIR" ]]; then
        log "No snapshots directory."
        return
    fi

    local all_snaps
    all_snaps=$(ls -1 "$SNAPSHOT_DIR" 2>/dev/null | sort -r)
    local total
    total=$(echo "$all_snaps" | wc -l | tr -d ' ')

    if [[ "$total" -le "$keep" ]]; then
        ok "Only ${total} snapshots — keeping all (threshold: ${keep})."
        return
    fi

    local to_delete
    to_delete=$(echo "$all_snaps" | tail -n +"$((keep + 1))")
    local delete_count
    delete_count=$(echo "$to_delete" | wc -l | tr -d ' ')

    log "Deleting ${delete_count} old snapshots (keeping newest ${keep})..."
    echo "$to_delete" | while IFS= read -r snap; do
        [[ -z "$snap" ]] && continue
        rm -rf "${SNAPSHOT_DIR:?}/$snap"
        echo -e "  ${DIM}deleted: $snap${NC}"
    done
    ok "Cleaned up ${delete_count} snapshots."
}

# ─── CLI ──────────────────────────────────────────────────────────
case "${1:-}" in
    show)
        cmd_show "${2:-}"
        ;;
    diff)
        cmd_diff "${2:-}" "${3:-}"
        ;;
    restore)
        cmd_restore "${2:-}" "${3:-}"
        ;;
    clean)
        cmd_clean "${2:-}" "${3:-}"
        ;;
    --help|-h)
        echo "gt-rescue: Recover branches from gt-drain snapshots."
        echo ""
        echo "Usage:"
        echo "  gt-rescue                          List all snapshots"
        echo "  gt-rescue show <id|--last>         Show snapshot details"
        echo "  gt-rescue diff <id|--last> [branch] Compare snapshot vs current"
        echo "  gt-rescue restore <id|--last> [branch] Restore to snapshot state"
        echo "  gt-rescue clean [--keep N]         Delete old snapshots (default: keep 10)"
        echo ""
        echo "Snapshots are created automatically by gt-drain before every restack."
        echo "Location: ~/.gt-drain/snapshots/"
        ;;
    "")
        cmd_list
        ;;
    *)
        err "Unknown command: $1"
        err "Run 'gt-rescue --help' for usage."
        exit 1
        ;;
esac
